# ─── App ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
LOG_LEVEL=debug
TZ=Europe/Istanbul

# ─── Database (Docker compose) ──────────────────────────────────
DATABASE_URL="postgresql://markaradar:dev_password_change_me@localhost:5434/markaradar_dev?schema=public"

# ─── Redis (Docker compose) ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6390
REDIS_PASSWORD=
REDIS_DB=0
QUEUE_REDIS_DB=1

# ─── Auth ───────────────────────────────────────────────────────
JWT_SECRET=change_me_long_random_string_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_different_long_random_string
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_DOMAIN=localhost

# ─── Storage (yerel: MinIO, prod: R2) ───────────────────────────
STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9110
S3_REGION=auto
S3_BUCKET=markaradar-media
S3_ACCESS_KEY=markaradar
S3_SECRET_KEY=dev_minio_password
S3_PUBLIC_URL=http://localhost:9110/markaradar-media

# ─── AI Providers (gerçek key gir) ──────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEFAULT_AI_MODEL=gpt-4o-mini
AI_MONTHLY_BUDGET_USD=500

# ─── Mail GİDEN (yerel: MailHog SMTP, prod: Resend) ─────────────
# Sıralama: RESEND_API_KEY varsa Resend kullanılır, yoksa SMTP.
MAIL_FROM=hello@markaradar.com
MAIL_FROM_NAME=MarkaRadar
RESEND_API_KEY=
SMTP_HOST=localhost
SMTP_PORT=1030
SMTP_USER=
SMTP_PASS=
SMTP_TLS_REJECT_UNAUTHORIZED=true

# ─── Mail GELEN (IMAP — gelen kutusu için) ──────────────────────
# Boş bırakırsan inbox modülü çalışır ama "Yenile" butonu hata verir.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_SECURE=true
IMAP_TLS_REJECT_UNAUTHORIZED=true

# ─── Newsletter (Beehiiv) ───────────────────────────────────────
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ─── Payment ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ─── Monitoring ─────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=

# ─── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3003,http://localhost:3004

# ─── Rate limit ─────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
