  priceUsd        Decimal             @default(0) @map("price_usd") @db.Decimal(10, 2)
  earlyBirdPriceTry Decimal?          @map("early_bird_price_try") @db.Decimal(12, 2)
  capacity        Int?

  syllabus        Json?               // [{week:1, title:"", topics:[]}]
