// MarkaRadar — Prisma schema (Sprint 1: temel tablolar)
// Tüm tablolar zamanla buraya eklenecek. Şu an: User + Category + Tag + Article minimum set.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// USERS & AUTH
// ──────────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  editor
  writer
  social_manager
  sales
  agency_user
  brand_user
  reader
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  fullName      String    @map("full_name") @db.VarChar(150)
  role          UserRole  @default(reader)
  avatarUrl     String?   @map("avatar_url")
  bio           String?   @db.Text
  linkedinUrl   String?   @map("linkedin_url")
  twitterUrl    String?   @map("twitter_url")
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  articles            Article[]
  refreshTokens       RefreshToken[]
  notifications       Notification[]
  calendarEventsOwned CalendarEvent[]
  subscriptions       Subscription[]
  pageContentsUpdated PageContent[]   @relation("PageContentUpdatedBy")

  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz()
  userAgent String?  @map("user_agent") @db.VarChar(500)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ──────────────────────────────────────────────────────────────
// CONTENT
// ──────────────────────────────────────────────────────────────

model Category {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique @db.VarChar(120)
  name           String   @db.VarChar(120)
  description    String?  @db.Text
  parentId       String?  @map("parent_id") @db.Uuid
  coverUrl       String?  @map("cover_url")
  seoTitle       String?  @map("seo_title") @db.VarChar(160)
  seoDescription String?  @map("seo_description") @db.VarChar(320)
  orderIndex     Int      @default(0) @map("order_index")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  articles Article[]

  @@index([parentId])
  @@map("categories")
}

enum TagType {
  topic
  brand
  agency
  person
  campaign
  tool
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique @db.VarChar(120)
  name      String   @db.VarChar(120)
  type      TagType  @default(topic)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  articles ArticleTag[]

  @@index([type])
  @@map("tags")
}

enum ArticleStatus {
  draft
  in_review
  scheduled
  published
  archived
}

model Article {
  id          String        @id @default(uuid()) @db.Uuid
  slug        String        @unique @db.VarChar(200)
  title       String        @db.VarChar(200)
  spot        String?       @db.VarChar(320)
  body        String        @db.Text
  coverUrl    String?       @map("cover_url")
  coverAlt    String?       @map("cover_alt") @db.VarChar(200)
  categoryId  String?       @map("category_id") @db.Uuid
  authorId    String?       @map("author_id") @db.Uuid
  readingTime Int?          @map("reading_time_min")

  // AI alanları
  aiSummary         String?  @map("ai_summary") @db.Text
  aiWhyMatters      String?  @map("ai_why_matters") @db.Text
  aiBrandTakeaways  Json?    @map("ai_brand_takeaways")
  aiAgencyTakeaways Json?    @map("ai_agency_takeaways")
  aiTrAdaptation    String?  @map("ai_tr_adaptation") @db.Text
  aiGeneratedBy     String?  @map("ai_generated_by") @db.VarChar(50)
  aiGeneratedAt     DateTime? @map("ai_generated_at") @db.Timestamptz()
  aiHumanRatio      Int?     @map("ai_human_ratio") // 0-100: ne kadar AI

  // Yayın
  status      ArticleStatus @default(draft)
  publishedAt DateTime?     @map("published_at") @db.Timestamptz()
  scheduledAt DateTime?     @map("scheduled_at") @db.Timestamptz()

  // SEO
  seoTitle       String? @map("seo_title") @db.VarChar(160)
  seoDescription String? @map("seo_description") @db.VarChar(320)
  canonicalUrl   String? @map("canonical_url")
  ogImageUrl     String? @map("og_image_url")

  // Premium
  isPremium      Boolean @default(false) @map("is_premium")

  // Sponsorluk
  isSponsored    Boolean @default(false) @map("is_sponsored")
  sponsorLabel   String? @map("sponsor_label") @db.VarChar(100)

  // Kaynak
  sourceUrl    String? @map("source_url")
  sourceName   String? @map("source_name") @db.VarChar(120)

  // Metrikler
  viewCount    BigInt @default(0) @map("view_count")
  shareCount   Int    @default(0) @map("share_count")

  // Audit
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  category Category?    @relation(fields: [categoryId], references: [id])
  author         User?           @relation(fields: [authorId], references: [id])
  tags           ArticleTag[]
  calendarEvents CalendarEvent[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([categoryId, publishedAt(sort: Desc)])
  @@index([slug])
  @@map("articles")
}

model ArticleTag {
  articleId String @map("article_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

// ──────────────────────────────────────────────────────────────
// MAIL — gelen (IMAP) + giden (SMTP/Resend) tek panel
// ──────────────────────────────────────────────────────────────

enum EmailDirection {
  INBOUND
  OUTBOUND
}

enum EmailStatus {
  UNREAD
  READ
  DELETED
}

model EmailMessage {
  id            String         @id @default(uuid()) @db.Uuid
  direction     EmailDirection
  status        EmailStatus    @default(UNREAD)

  // IMAP dedup
  imapUid       String?        @map("imap_uid") @db.VarChar(50)
  imapFolder    String         @default("INBOX") @map("imap_folder") @db.VarChar(50)
  messageId     String?        @map("message_id") @db.VarChar(500)
  inReplyTo     String?        @map("in_reply_to") @db.VarChar(500)
  threadKey     String?        @map("thread_key") @db.VarChar(200)

  // Adresler
  fromAddress   String         @map("from_address") @db.VarChar(255)
  fromName      String?        @map("from_name") @db.VarChar(200)
  toAddresses   String         @map("to_addresses") @db.Text
  ccAddresses   String?        @map("cc_addresses") @db.Text

  // İçerik
  subject       String         @default("") @db.VarChar(500)
  bodyText      String         @default("") @map("body_text") @db.Text
  bodyHtml      String         @default("") @map("body_html") @db.Text
  hasAttachment Boolean        @default(false) @map("has_attachment")

  receivedAt    DateTime       @default(now()) @map("received_at") @db.Timestamptz()
  fetchedAt     DateTime       @default(now()) @map("fetched_at") @db.Timestamptz()
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([imapFolder, imapUid])
  @@index([direction, status, receivedAt(sort: Desc)])
  @@index([threadKey])
  @@map("email_messages")
}

// ──────────────────────────────────────────────────────────────
// CALENDAR — editöryel, etkinlik, ajans toplantısı, hatırlatma
// ──────────────────────────────────────────────────────────────

enum CalendarEventType {
  EDITORIAL        // Makale yayın planı
  MEETING          // CMO / ajans görüşmesi
  EVENT            // Şirket etkinliği (zirve, ödül töreni)
  WEBINAR          // Premium webinar
  COURSE_SESSION   // Akademi kohort oturumu
  CAMPAIGN         // Pazarlama kampanyası aksiyon
  REMINDER         // Genel hatırlatma
  OTHER
}

enum CalendarEventStatus {
  PLANNED
  IN_PROGRESS
  DONE
  CANCELLED
}

model CalendarEvent {
  id               String              @id @default(uuid()) @db.Uuid
  type             CalendarEventType
  status           CalendarEventStatus @default(PLANNED)
  title            String              @db.VarChar(300)
  description      String?             @db.Text
  startsAt         DateTime            @map("starts_at") @db.Timestamptz()
  endsAt           DateTime?           @map("ends_at") @db.Timestamptz()
  allDay           Boolean             @default(false) @map("all_day")
  color            String?             @db.VarChar(20)

  // Lokasyon (fiziksel + sanal)
  location         String?             @db.VarChar(300)
  meetingUrl       String?             @map("meeting_url") @db.Text

  // Davetli e-postaları
  attendees        String[]            @default([])

  // Domain bağlantıları (opsiyonel)
  articleId        String?             @map("article_id") @db.Uuid
  article          Article?            @relation(fields: [articleId], references: [id], onDelete: SetNull)
  agencyId         String?             @map("agency_id") @db.Uuid
  eventRefId       String?             @map("event_ref_id") @db.Uuid
  courseCohortId   String?             @map("course_cohort_id") @db.Uuid

  // Hatırlatma + tekrarlanma
  remindBefore     Int?                @map("remind_before") // dakika cinsinden
  recurrence       String?             @db.VarChar(50)       // daily/weekly/monthly

  notes            String?             @db.Text

  createdById      String?             @map("created_by") @db.Uuid
  createdBy        User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([startsAt])
  @@index([type, status])
  @@index([articleId])
  @@index([createdById])
  @@map("calendar_events")
}

// ──────────────────────────────────────────────────────────────
// NOTIFICATIONS — in-app + WebSocket gerçek-zamanlı
// ──────────────────────────────────────────────────────────────

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  type        String    @db.VarChar(80)
  // Bkz notifications.service.ts NotificationType
  title       String    @db.VarChar(300)
  body        String?   @db.Text
  link        String?   @db.VarChar(500)
  metadata    Json?
  read        Boolean   @default(false)
  readAt      DateTime? @map("read_at") @db.Timestamptz()

  // Belirli kullanıcıya (null = tüm admin'lere broadcast)
  userId      String?   @map("user_id") @db.Uuid
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId, read, createdAt(sort: Desc)])
  @@index([type])
  @@map("notifications")
}

// ──────────────────────────────────────────────────────────────
// AUDIT LOG — kim ne yaptı (KVKK için zorunlu)
// ──────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorId     String?  @map("actor_id") @db.Uuid
  actorEmail  String?  @map("actor_email") @db.VarChar(255)
  action      String   @db.VarChar(80)  // article.publish, user.role_change, vb
  resource    String   @db.VarChar(50)  // article, user, agency, subscription
  resourceId  String?  @map("resource_id") @db.VarChar(100)
  success     Boolean  @default(true)
  changes     Json?    // before/after diff
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  errorMessage String? @map("error_message") @db.Text

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([actorId, createdAt(sort: Desc)])
  @@index([resource, resourceId])
  @@index([action])
  @@map("audit_logs")
}

// ──────────────────────────────────────────────────────────────
// EMAIL VERIFICATION & PASSWORD RESET tokenları
// ──────────────────────────────────────────────────────────────

model VerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(255)
  type      String   @db.VarChar(40) // email_verify | password_reset
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId, type])
  @@index([tokenHash])
  @@map("verification_tokens")
}

// ──────────────────────────────────────────────────────────────
// SUBSCRIPTIONS — MarkaRadar+ premium üyelik
// ──────────────────────────────────────────────────────────────

enum SubscriptionTier {
  founding_member    // $49/yr lifetime price lock
  lite               // $99/yr
  pro                // $499/yr — CMO Club Slack erişimi
  enterprise         // $2999/yr — 5 koltuk
}

enum SubscriptionStatus {
  trialing
  active
  past_due           // ödeme başarısız, retry'da
  canceled
  expired
  paused
}

enum PaymentProvider {
  stripe
  iyzico
  manual
}

enum BillingInterval {
  monthly
  yearly
}

model Subscription {
  id                     String              @id @default(uuid()) @db.Uuid
  userId                 String              @map("user_id") @db.Uuid
  tier                   SubscriptionTier
  status                 SubscriptionStatus  @default(trialing)
  billingInterval        BillingInterval     @default(yearly) @map("billing_interval")

  amountUsd              Decimal             @default(0) @map("amount_usd") @db.Decimal(10, 2)
  amountTry              Decimal             @default(0) @map("amount_try") @db.Decimal(12, 2)
  currency               String              @default("USD") @db.VarChar(3)

  provider               PaymentProvider
  providerCustomerId     String?             @map("provider_customer_id") @db.VarChar(120)
  providerSubscriptionId String?             @unique @map("provider_subscription_id") @db.VarChar(120)

  trialEndsAt            DateTime?           @map("trial_ends_at") @db.Timestamptz()
  startedAt              DateTime?           @map("started_at") @db.Timestamptz()
  currentPeriodStart     DateTime?           @map("current_period_start") @db.Timestamptz()
  currentPeriodEnd       DateTime?           @map("current_period_end") @db.Timestamptz()
  cancelAtPeriodEnd      Boolean             @default(false) @map("cancel_at_period_end")
  canceledAt             DateTime?           @map("canceled_at") @db.Timestamptz()

  failedPaymentCount     Int                 @default(0) @map("failed_payment_count")
  lastPaymentError       String?             @map("last_payment_error") @db.Text
  nextRetryAt            DateTime?           @map("next_retry_at") @db.Timestamptz()

  metadata               Json?

  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime            @updatedAt @map("updated_at") @db.Timestamptz()

  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments               Payment[]

  @@index([userId, status])
  @@index([status, currentPeriodEnd])
  @@index([nextRetryAt])
  @@map("subscriptions")
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
  canceled
}

model Payment {
  id                String          @id @default(uuid()) @db.Uuid
  subscriptionId    String?         @map("subscription_id") @db.Uuid
  userId            String          @map("user_id") @db.Uuid

  provider          PaymentProvider
  providerPaymentId String?         @unique @map("provider_payment_id") @db.VarChar(120)
  providerInvoiceId String?         @map("provider_invoice_id") @db.VarChar(120)

  amount            Decimal         @db.Decimal(12, 2)
  currency          String          @db.VarChar(3)
  status            PaymentStatus   @default(pending)
  description       String?         @db.VarChar(300)

  errorCode         String?         @map("error_code") @db.VarChar(80)
  errorMessage      String?         @map("error_message") @db.Text

  paidAt            DateTime?       @map("paid_at") @db.Timestamptz()
  refundedAt        DateTime?       @map("refunded_at") @db.Timestamptz()

  metadata          Json?

  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz()

  subscription      Subscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([subscriptionId])
  @@map("payments")
}

model WebhookEvent {
  id          String          @id @default(uuid()) @db.Uuid
  provider    PaymentProvider
  eventId     String          @map("event_id") @db.VarChar(200)
  eventType   String          @map("event_type") @db.VarChar(100)
  payload     Json
  processedAt DateTime?       @map("processed_at") @db.Timestamptz()
  error       String?         @db.Text
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([provider, eventId])
  @@index([processedAt])
  @@map("webhook_events")
}

// ──────────────────────────────────────────────────────────────
// AGENCIES — ajans rehberi + tier sistemi
// ──────────────────────────────────────────────────────────────

enum AgencyTier {
  free
  basic        // 990 TL/ay
  premium      // 2.490 TL/ay
  featured     // 6.900 TL/ay
  elite        // 14.900 TL/ay
}

enum AgencyVerificationLevel {
  unverified
  email_verified
  linkedin_verified
  fully_verified  // editör görüşme yapmış
}

model Agency {
  id                String        @id @default(uuid()) @db.Uuid
  slug              String        @unique @db.VarChar(150)
  name              String        @db.VarChar(150)
  logoUrl           String?       @map("logo_url")
  coverUrl          String?       @map("cover_url")
  tagline           String?       @db.VarChar(300)
  description       String?       @db.Text

  // Şirket bilgi
  foundedYear       Int?          @map("founded_year")
  teamSizeRange     String?       @map("team_size_range") @db.VarChar(50)
  // 1-10, 11-50, 51-100, 100+
  city              String?       @db.VarChar(80)
  country           String        @default("TR") @db.VarChar(80)
  website           String?       @db.Text
  email             String?       @db.VarChar(255)
  phone             String?       @db.VarChar(50)
  linkedinUrl       String?       @map("linkedin_url") @db.Text
  instagramUrl      String?       @map("instagram_url") @db.Text

  // Servisler / endüstri / referanslar
  services          String[]      @default([])
  industries        String[]      @default([])
  clientReferences  String[]      @default([]) @map("client_references")

  // Awards + featured works
  awards            Json?
  featuredWorks     Json?         @map("featured_works")

  // Tier yönetimi
  tier              AgencyTier    @default(free)
  tierStartsAt      DateTime?     @map("tier_starts_at") @db.Timestamptz()
  tierEndsAt        DateTime?     @map("tier_ends_at") @db.Timestamptz()

  // Verification
  verificationLevel AgencyVerificationLevel @default(unverified) @map("verification_level")
  verifiedAt        DateTime?     @map("verified_at") @db.Timestamptz()

  // Cached rating (review aggregate)
  ratingAvg         Decimal       @default(0) @map("rating_avg") @db.Decimal(3, 2)
  reviewCount       Int           @default(0) @map("review_count")

  // Audit
  ownerUserId       String?       @map("owner_user_id") @db.Uuid
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  reviews           AgencyReview[]

  @@index([tier, isActive])
  @@index([city])
  @@index([ratingAvg(sort: Desc), reviewCount(sort: Desc)])
  @@map("agencies")
}

enum ReviewVerificationStatus {
  pending           // otomatik kontrol bekliyor
  email_pending     // doğrulama maili gönderildi, click bekleniyor
  email_verified
  linkedin_verified
  fully_verified    // editör görüşme yapmış
  rejected
}

enum ReviewPublicationStatus {
  draft
  submitted          // moderasyon kuyruğunda
  published
  hidden_by_admin
  withdrawn_by_user
}

model AgencyReview {
  id                 String                    @id @default(uuid()) @db.Uuid
  agencyId           String                    @map("agency_id") @db.Uuid

  // Reviewer (gerçek ad zorunlu — anonim yok)
  reviewerName       String                    @map("reviewer_name") @db.VarChar(150)
  reviewerRole       String?                   @map("reviewer_role") @db.VarChar(100)
  reviewerEmail      String                    @map("reviewer_email") @db.VarChar(255)
  reviewerCompany    String?                   @map("reviewer_company") @db.VarChar(150)
  reviewerLinkedin   String?                   @map("reviewer_linkedin") @db.Text

  // Proje detayları
  projectType        String?                   @map("project_type") @db.VarChar(80)
  projectBudgetRange String?                   @map("project_budget_range") @db.VarChar(50)
  projectDurationMonths Int?                   @map("project_duration_months")
  projectStartedAt   DateTime?                 @map("project_started_at") @db.Timestamptz()

  // Puanlama
  ratingOverall      Int                       @map("rating_overall")
  ratingQuality      Int                       @map("rating_quality")
  ratingCommunication Int                      @map("rating_communication")
  ratingTimeline     Int                       @map("rating_timeline")
  ratingValue        Int                       @map("rating_value")

  title              String                    @db.VarChar(200)
  content            String                    @db.Text
  pros               String?                   @db.Text
  cons               String?                   @db.Text
  wouldWorkAgain     String?                   @map("would_work_again") @db.VarChar(20)
  // yes | maybe | no
  npsScore           Int?                      @map("nps_score")

  // Verification + moderation state
  verificationStatus ReviewVerificationStatus  @default(pending) @map("verification_status")
  verificationToken  String?                   @map("verification_token") @db.VarChar(255)
  verifiedAt         DateTime?                 @map("verified_at") @db.Timestamptz()
  publicationStatus  ReviewPublicationStatus   @default(submitted) @map("publication_status")
  moderationNotes    String?                   @map("moderation_notes") @db.Text
  moderatedById      String?                   @map("moderated_by") @db.Uuid

  // Anti-fraud
  ipAddress          String?                   @map("ip_address") @db.VarChar(45)
  userAgent          String?                   @map("user_agent") @db.VarChar(500)
  similarityScore    Decimal?                  @map("similarity_score") @db.Decimal(4, 3)

  // Right to reply
  agencyResponse     String?                   @map("agency_response") @db.Text
  agencyResponseAt   DateTime?                 @map("agency_response_at") @db.Timestamptz()

  // Audit
  createdAt          DateTime                  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime                  @updatedAt @map("updated_at") @db.Timestamptz()

