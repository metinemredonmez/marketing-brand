model Bookmark {
  id              String         @id @default(uuid()) @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  articleId       String?        @map("article_id") @db.Uuid
  agencyId        String?        @map("agency_id") @db.Uuid
  jobId           String?        @map("job_id") @db.Uuid
  reportId        String?        @map("report_id") @db.Uuid
  notes           String?        @db.Text
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([userId, articleId])
  @@unique([userId, agencyId])
  @@unique([userId, jobId])
  @@unique([userId, reportId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("bookmarks")
}

// ──────────────────────────────────────────────────────────────
// COMMUNITY — CMO Club Slack
// ──────────────────────────────────────────────────────────────

model CommunityMember {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  community       String   @db.VarChar(50)
  slackUserId     String?  @map("slack_user_id") @db.VarChar(80)
  slackChannelId  String?  @map("slack_channel_id") @db.VarChar(80)
  badges          String[] @default([])
  joinedAt        DateTime @default(now()) @map("joined_at") @db.Timestamptz()
  isActive        Boolean  @default(true) @map("is_active")

  @@unique([userId, community])
  @@index([community, isActive])
  @@map("community_members")
}

// ──────────────────────────────────────────────────────────────
// AI Generations — strateji doc 7.x'ten
// ──────────────────────────────────────────────────────────────

model AiGeneration {
  id              String   @id @default(uuid()) @db.Uuid
  articleId       String?  @map("article_id") @db.Uuid
  generationType  String   @map("generation_type") @db.VarChar(50)
  // title, spot, summary, why_matters, brand_takeaways, agency_takeaways,
  // linkedin_post, instagram_carousel, reels_script, seo_meta, cover_image
  prompt          String   @db.Text
  output          String   @db.Text
  model           String   @db.VarChar(80)
  provider        String   @default("openai") @db.VarChar(30)
  // openai | anthropic | gemini
  promptTokens    Int      @default(0) @map("prompt_tokens")
  outputTokens    Int      @default(0) @map("output_tokens")
  costUsd         Decimal  @default(0) @map("cost_usd") @db.Decimal(10, 4)
  durationMs      Int      @default(0) @map("duration_ms")
  status          String   @default("success") @db.VarChar(30)
  // success | error | cached
  errorMessage    String?  @map("error_message") @db.Text
  createdById     String?  @map("created_by") @db.Uuid

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([articleId])
  @@index([createdAt(sort: Desc)])
  @@index([provider, createdAt(sort: Desc)])
  @@map("ai_generations")
}

// ──────────────────────────────────────────────────────────────
// BRAND STUDIO — self-serve reklam platformu
// ──────────────────────────────────────────────────────────────

enum BrandAccountStatus {
  pending_kyc          // KYC bilgisi bekleniyor
  active
  suspended
  closed
}

enum BrandAccountRole {
  owner
  manager
  viewer
}

model BrandAccount {
  id               String                @id @default(uuid()) @db.Uuid
  slug             String                @unique @db.VarChar(150)
  companyName      String                @map("company_name") @db.VarChar(200)
  taxNumber        String?               @map("tax_number") @db.VarChar(20)
  /// Vergi dairesi
  taxOffice        String?               @map("tax_office") @db.VarChar(100)
  contactName      String                @map("contact_name") @db.VarChar(150)
  contactEmail     String                @unique @map("contact_email") @db.VarChar(255)
  contactPhone     String?               @map("contact_phone") @db.VarChar(50)
  website          String?               @db.Text
  logoUrl          String?               @map("logo_url") @db.Text
  industry         String?               @db.VarChar(80)
  companySize      String?               @map("company_size") @db.VarChar(50)
  status           BrandAccountStatus    @default(pending_kyc)

  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz()

  users            BrandAccountUser[]
  wallet           BrandWallet?
  creatives        BrandCreative[]
  advertiser       Advertiser?

  @@index([status])
  @@map("brand_accounts")
}

model BrandAccountUser {
  id               String              @id @default(uuid()) @db.Uuid
  brandAccountId   String              @map("brand_account_id") @db.Uuid
  userId           String              @map("user_id") @db.Uuid
  role             BrandAccountRole    @default(viewer)
  invitedAt        DateTime            @default(now()) @map("invited_at") @db.Timestamptz()
  acceptedAt       DateTime?           @map("accepted_at") @db.Timestamptz()

  brandAccount     BrandAccount        @relation(fields: [brandAccountId], references: [id], onDelete: Cascade)

  @@unique([brandAccountId, userId])
  @@index([userId])
  @@map("brand_account_users")
}

model BrandWallet {
  id               String                 @id @default(uuid()) @db.Uuid
  brandAccountId   String                 @unique @map("brand_account_id") @db.Uuid
  balanceTry       Decimal                @default(0) @map("balance_try") @db.Decimal(12, 2)
  totalRechargedTry Decimal               @default(0) @map("total_recharged_try") @db.Decimal(14, 2)
  totalSpentTry    Decimal                @default(0) @map("total_spent_try") @db.Decimal(14, 2)

  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime               @updatedAt @map("updated_at") @db.Timestamptz()

  brandAccount     BrandAccount           @relation(fields: [brandAccountId], references: [id], onDelete: Cascade)
  transactions     WalletTransaction[]

  @@map("brand_wallets")
}

enum WalletTransactionType {
  recharge         // bakiye yükleme
  spend            // kampanya harcaması
  refund           // iade
  bonus            // promosyon bonusu
  adjustment       // admin manuel düzeltme
}

model WalletTransaction {
  id               String                  @id @default(uuid()) @db.Uuid
  walletId         String                  @map("wallet_id") @db.Uuid
  type             WalletTransactionType
  amountTry        Decimal                 @map("amount_try") @db.Decimal(12, 2)
  balanceBefore    Decimal                 @map("balance_before") @db.Decimal(12, 2)
  balanceAfter     Decimal                 @map("balance_after") @db.Decimal(12, 2)
  description      String                  @db.VarChar(300)
  campaignId       String?                 @map("campaign_id") @db.Uuid
  stripePaymentId  String?                 @map("stripe_payment_id") @db.VarChar(120)
  metadata         Json?

  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz()

  wallet           BrandWallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt(sort: Desc)])
  @@index([campaignId])
  @@map("wallet_transactions")
}

enum BrandCreativeType {
  banner               // banner reklam görseli + click URL
  sponsored_article    // Marka Hamlesi tarzı sponsorlu makale
  newsletter_blurb     // newsletter'da 80 kelimelik sponsor metin
  linkedin_post        // LinkedIn sponsor postu
  reels_script         // Reels/Story video script
}

enum BrandCreativeStatus {
  draft
  ready                // firma onayladı, kullanıma hazır
  in_campaign          // aktif kampanyada
  archived
}

model BrandCreative {
  id               String                  @id @default(uuid()) @db.Uuid
  brandAccountId   String                  @map("brand_account_id") @db.Uuid
  type             BrandCreativeType
  name             String                  @db.VarChar(200)
  /// AI üretim çıktısı + manuel düzenleme — schema type'a göre değişir
  content          Json
  /// AI üretimden geliyorsa referans
  aiGenerationId   String?                 @map("ai_generation_id") @db.Uuid
  /// Banner için görsel URL, sponsor article için cover, vb.
  assetUrl         String?                 @map("asset_url") @db.Text
  clickUrl         String?                 @map("click_url") @db.Text
  altText          String?                 @map("alt_text") @db.VarChar(300)

  status           BrandCreativeStatus     @default(draft)
  campaignId       String?                 @map("campaign_id") @db.Uuid

  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime                @updatedAt @map("updated_at") @db.Timestamptz()

  brandAccount     BrandAccount            @relation(fields: [brandAccountId], references: [id], onDelete: Cascade)
  campaign         AdCampaign?             @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([brandAccountId, status])
  @@index([type])
  @@map("brand_creatives")
}

// ════════════════════════════════════════════════════════════════
// PAGE CONTENT CMS — landing/marketing sayfalarının admin tarafından
// düzenlenebilir, block-tabanlı içerikleri.
//
// slug    → "landing-hero", "landing-faq", "hakkimizda", "kvkk", ...
// blocks  → JSON array of block objects:
//             - { type: "hero", title, subtitle, eyebrow, ctaLabel, ctaHref }
//             - { type: "feature-grid", items: [{ title, desc, icon }] }
//             - { type: "faq", items: [{ q, a }] }
//             - { type: "text", html }
//             - { type: "cta-banner", title, subtitle, ctaLabel, ctaHref }
// locale  → "tr" | "en"
// ════════════════════════════════════════════════════════════════
model PageContent {
  id           String      @id @default(uuid()) @db.Uuid
  slug         String      @db.VarChar(80)
  locale       String      @default("tr") @db.VarChar(5)
  title        String?     @db.VarChar(200)
  /// JSON block array
  blocks       Json
  isPublished  Boolean     @default(true) @map("is_published")
  updatedById  String?     @map("updated_by_id") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz()

  updatedBy    User?       @relation("PageContentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([slug, locale])
  @@index([isPublished])
  @@map("page_contents")
}
