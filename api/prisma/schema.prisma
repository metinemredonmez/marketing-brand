// ──────────────────────────────────────────────────────────────
// ADS — banner + sponsorlu
// ──────────────────────────────────────────────────────────────

enum AdvertiserStatus {
  active
  inactive
}

model Advertiser {
  id              String              @id @default(uuid()) @db.Uuid
  name            String              @db.VarChar(200)
  contactName     String?             @map("contact_name") @db.VarChar(150)
  contactEmail    String?             @map("contact_email") @db.VarChar(255)
  contactPhone    String?             @map("contact_phone") @db.VarChar(50)
  billingInfo     Json?               @map("billing_info")
  status          AdvertiserStatus    @default(active)
  /// Self-serve Brand Account ile bağlantı (varsa)
  brandAccountId  String?             @unique @map("brand_account_id") @db.Uuid
  brandAccount    BrandAccount?       @relation(fields: [brandAccountId], references: [id], onDelete: SetNull)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  campaigns       AdCampaign[]

  @@map("advertisers")
}

enum AdCampaignType {
  banner
  sponsored_content
  newsletter
  native
  agency_premium
  job_premium
}

enum AdCampaignStatus {
  draft
  pending_approval     // self-serve onay bekliyor
  scheduled
  active
  paused
  completed
  canceled
  rejected
}

enum AdCampaignSource {
  manual               // sales tarafından oluşturuldu
  self_serve           // firma kendi paneli üzerinden
}

model AdCampaign {
  id              String              @id @default(uuid()) @db.Uuid
  advertiserId    String              @map("advertiser_id") @db.Uuid
  name            String              @db.VarChar(200)
  type            AdCampaignType
  source          AdCampaignSource    @default(manual)
  goal            String?             @db.VarChar(50)
  // awareness, traffic, lead_gen, brand_story

  startAt         DateTime            @map("start_at") @db.Timestamptz()
  endAt           DateTime            @map("end_at") @db.Timestamptz()
  budget          Decimal             @db.Decimal(12, 2)
  spentTry        Decimal             @default(0) @map("spent_try") @db.Decimal(12, 2)
  currency        String              @default("TRY") @db.VarChar(10)
  targeting       Json?
  status          AdCampaignStatus    @default(draft)

  // Self-serve moderation
  submittedAt     DateTime?           @map("submitted_at") @db.Timestamptz()
  approvedById    String?             @map("approved_by") @db.Uuid
  approvedAt      DateTime?           @map("approved_at") @db.Timestamptz()
  rejectedReason  String?             @map("rejected_reason") @db.Text

  // Performance cache
  totalImpressions BigInt             @default(0) @map("total_impressions")
  totalClicks     BigInt              @default(0) @map("total_clicks")

  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  advertiser      Advertiser          @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  slots           AdSlot[]
  brandCreatives  BrandCreative[]

  @@index([status, startAt])
  @@index([advertiserId, status])
  @@index([source])
  @@map("ad_campaigns")
}

enum AdPlacement {
  homepage_top
  category_top
  article_inline
  sidebar_sticky
  mobile_sticky
  newsletter_top
}

model AdSlot {
  id              String              @id @default(uuid()) @db.Uuid
  campaignId      String              @map("campaign_id") @db.Uuid
  placement       AdPlacement
  creativeUrl     String              @map("creative_url") @db.Text
  clickUrl        String              @map("click_url") @db.Text
  altText         String?             @map("alt_text") @db.VarChar(200)
  weight          Int                 @default(1)
  startAt         DateTime            @map("start_at") @db.Timestamptz()
  endAt           DateTime            @map("end_at") @db.Timestamptz()
  impressions     BigInt              @default(0)
  clicks          BigInt              @default(0)
  status          String              @default("active") @db.VarChar(30)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  campaign        AdCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([placement, status, startAt, endAt])
  @@map("ad_slots")
}

