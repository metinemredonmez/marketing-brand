# ═══════════════════════════════════════════════════════════════
# MarkaRadar — PRODUCTION env (kopyala .env.prod yap)
# Sırrı olan tüm değerleri rasgele güçlü değerlerle değiştir.
# ═══════════════════════════════════════════════════════════════

# ── Domains
WEB_DOMAIN=markaradar.com
API_DOMAIN=api.markaradar.com
ADMIN_DOMAIN=admin.markaradar.com

WEB_URL=https://markaradar.com
API_URL=https://api.markaradar.com
ADMIN_URL=https://admin.markaradar.com

# ── Postgres
POSTGRES_USER=markaradar
POSTGRES_PASSWORD=                # openssl rand -base64 32
POSTGRES_DB=markaradar_prod

# ── Redis
REDIS_PASSWORD=                   # openssl rand -base64 32

# ── JWT secret'lar (en az 32 char, rasgele)
JWT_SECRET=                       # openssl rand -base64 48
JWT_REFRESH_SECRET=               # openssl rand -base64 48

# ── AI sağlayıcıları
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Ödeme
STRIPE_SECRET_KEY=                # sk_live_...
STRIPE_WEBHOOK_SECRET=            # whsec_...
STRIPE_PRICE_FOUNDING_YEARLY=     # price_...
STRIPE_PRICE_LITE_YEARLY=
STRIPE_PRICE_LITE_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=

IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_PLAN_FOUNDING_YEARLY=
IYZICO_PLAN_LITE_YEARLY=
IYZICO_PLAN_LITE_MONTHLY=
IYZICO_PLAN_PRO_YEARLY=
IYZICO_PLAN_PRO_MONTHLY=

# ── E-posta (Resend)
RESEND_API_KEY=                   # re_...
RESEND_FROM_EMAIL=noreply@markaradar.com

# ── Medya storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=markaradar-media
R2_PUBLIC_URL=https://media.markaradar.com

# ── Sentry (3 ayrı project DSN)
SENTRY_DSN=                       # API
NEXT_PUBLIC_WEB_SENTRY_DSN=
NEXT_PUBLIC_ADMIN_SENTRY_DSN=

# ── Analytics
PLAUSIBLE_DOMAIN=markaradar.com
POSTHOG_KEY=

# ── Backup R2 (postgres dump'larını oraya at)
BACKUP_R2_BUCKET=markaradar-backups
BACKUP_R2_ENDPOINT=               # https://<account>.r2.cloudflarestorage.com
